## Required

# OpenRouter API key — how Kady reaches hosted models (OpenAI, Anthropic,
# Google, xAI, Qwen, …). Only required if you use OpenRouter models; if you
# run everything locally through Ollama, this can be left blank.
OPENROUTER_API_KEY=


## Model defaults (optional)

# Default model for the agent. This is a bare provider model id; the provider
# is set by DEFAULT_MODEL_PROVIDER below. You can also switch models per chat
# tab in the UI. (There is a single agent now — no separate "expert" model.)
DEFAULT_MODEL_ID="anthropic/claude-opus-4.8"
DEFAULT_MODEL_PROVIDER="openrouter"


## Optional: local Ollama server

# Host for a running `ollama serve`. Models pulled into Ollama show up in the
# model dropdown (as `ollama/<name>`) and run directly against your local
# daemon. Pick `DEFAULT_MODEL_ID` like `llama3` with DEFAULT_MODEL_PROVIDER or
# just choose an `ollama/*` model in the UI.
OLLAMA_BASE_URL=http://localhost:11434


## Optional: web access (pi-web-access)

# Web search, URL/PDF fetching, GitHub repo reading, and video understanding
# work out of the box with no key (Exa MCP fallback). Add keys to unlock the
# direct providers — they can also be set live from Settings → API keys.
# EXA_API_KEY=            # exa.ai — fast web + code search
# PERPLEXITY_API_KEY=     # perplexity.ai — synthesized answers with citations
# GEMINI_API_KEY=         # Google AI Studio — search fallback + YouTube/video understanding


## Optional: backend knobs

# Override the backend port / projects directory if needed.
# KADY_PORT=8000
# KADY_PROJECTS_ROOT=./projects
# Python interpreter used only for the .h5ad preview helper.
# KADY_PYTHON=python3


## Optional: Pipeline Builder (Archon sidecar)

# start.sh can stand up the Archon pipeline-builder sidecar alongside Kady.
# Port the sidecar listens on (its /api/health is polled at boot).
# ARCHON_PORT=3091
# Base URL the backend uses to reach the sidecar.
# ARCHON_BASE_URL=http://localhost:3091
# Base URL the frontend (browser) uses to embed the builder.
# NEXT_PUBLIC_ARCHON_URL=http://localhost:3091
# Where the Archon checkout lives; defaults to the sibling ../Archon of this repo.
# ARCHON_DIR=../Archon


## Optional: Raindrop Workshop (local agent-trace debugger — Console "Raindrop" tab)

# start.sh reuses an already-running Workshop, else launches `raindrop workshop serve`
# if the `raindrop` binary is present. Fully local (DB in ~/.raindrop); no cloud key,
# so nothing egresses. Install (OSS): curl -fsSL https://raindrop.sh/install | bash
# Port the Workshop UI listens on (also probed via the backend's /raindrop/health).
# RAINDROP_PORT=5899
# Base URL the backend uses to health-check Workshop.
# RAINDROP_BASE_URL=http://localhost:5899
# Base URL the frontend (browser) uses to embed the Workshop UI.
# NEXT_PUBLIC_RAINDROP_URL=http://localhost:5899
# Set to 1 to let start.sh auto-install Workshop via the OSS one-liner (off by default).
# KADY_INSTALL_RAINDROP=0
# Where the in-process Pi agent ships its traces. start.sh sets this to the local Workshop
# automatically; with NO RAINDROP_WRITE_KEY set, traces stay local (nothing egresses).
# RAINDROP_LOCAL_DEBUGGER=http://127.0.0.1:5899/v1/
# Setting a write key opts INTO Raindrop cloud (per-interaction billing + egress). Leave unset.
# RAINDROP_WRITE_KEY=


## Not used yet — being re-added as native tools

# The integrations below were part of the previous architecture and are not
# read by the current backend. They're listed here so you don't lose your
# values; literature search, document conversion, and remote compute will
# return as native tools in upcoming releases. (Web search is back — see the
# "web access" section above.)

# Web search
# PARALLEL_API_KEY=

# Paperclip literature / regulatory / clinical-trial search
# PAPERCLIP_API_KEY=

# Modal remote compute
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=

# Scientific databases and search
# NCBI_API_KEY=
# NCBI_EMAIL=
# S2_API_KEY=
# CORE_API_KEY=
# OPENALEX_API_KEY=

# Specialized scientific APIs
# ADAPTYV_API_KEY=
# ROWAN_API_KEY=
# MP_API_KEY=
# OMIM_API_KEY=
# BIOGRID_API_KEY=
# DISGENET_API_KEY=
# ADDGENE_API_KEY=
# CLUE_API_KEY=
# OPENFDA_API_KEY=
# PATENTSVIEW_API_KEY=
# DATACOMMONS_API_KEY=

# Government / economic data
# FRED_API_KEY=
# BEA_API_KEY=
# BLS_API_KEY=
# CENSUS_API_KEY=
# NASA_API_KEY=
# NOAA_API_KEY=
# OPENWEATHERMAP_API_KEY=
# ALPHAVANTAGE_API_KEY=

# Zotero reference manager
# ZOTERO_LIBRARY_ID=
# ZOTERO_API_KEY=
# ZOTERO_LIBRARY_TYPE=

# ML / AI platforms
# HUGGINGFACE_TOKEN=
# QISKIT_IBM_TOKEN=

# Other
